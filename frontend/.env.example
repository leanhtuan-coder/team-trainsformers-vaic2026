# ─── CareerRadar frontend env ───
# Copy file này thành .env.local rồi điền giá trị thật (.env.local đã được .gitignore).

# Backend Express (mặc định cổng 4000)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ─── Supabase Auth (Google login) ───
# Lấy tại: Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL = "Project URL" (dạng https://xxxx.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY = "Publishable key" (sb_publishable_...) — KHÔNG dùng secret key ở đây,
# biến NEXT_PUBLIC_* sẽ lộ ra trình duyệt.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
