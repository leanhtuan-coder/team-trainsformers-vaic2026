# ─── CareerRadar frontend env ───
# Copy file này thành .env.local rồi điền giá trị thật (.env.local đã được .gitignore).

# Backend Express (mặc định cổng 4000)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ─── Supabase Auth (Google login) ───
# Lấy tại: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
