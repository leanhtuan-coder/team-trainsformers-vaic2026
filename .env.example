# LLM Providers
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# ─── Chấm RIASEC 6 câu tự do (Chặng 1) bằng gpt-oss-120b — điền vào backend/.env (KHÔNG commit) ───
# Thứ tự ưu tiên: NVIDIA NIM trước (dùng chung key với chatbot /interview) → Groq dự phòng →
# thiếu cả hai thì tự fallback sang chấm bằng từ khoá (không chặn cứng luồng).
NVIDIA_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Vector Store (nếu dùng Pinecone thay vì Supabase pgvector)
PINECONE_API_KEY=your_key_here

# ─── Lưu trữ hồ sơ học sinh (Evidence Ledger) — Supabase Postgres, điền vào backend/.env ───
# Bắt buộc để backend chạy được (thay cho file JSON cũ, mất khi Render redeploy).
# Lấy tại: Supabase Dashboard → Project Settings → API. SERVICE_ROLE KEY rất nhạy cảm
# (bypass mọi RLS) — CHỈ đặt ở backend, KHÔNG BAO GIỜ đưa vào frontend/NEXT_PUBLIC_*.
# Chạy supabase/migrations/0002_profiles.sql trong Supabase SQL Editor trước khi dùng.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database
DATABASE_URL=your_supabase_url_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
