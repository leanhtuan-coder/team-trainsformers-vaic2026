# ─── CareerRadar backend env ───
# Copy file này thành .env rồi điền giá trị thật.

# API Key cho NVIDIA NIM (Llama 3.1 70B) sinh giải thích AI
NVIDIA_API_KEY=your_nvidia_api_key_here

# AI predict ngành sau onboarding (OpenAI-compatible; có thể trỏ về NVIDIA NIM).
# Nếu bỏ trống OPENAI_API_KEY, predictor sẽ dùng NVIDIA_API_KEY ở trên.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL_NAME=openai/gpt-oss-120b
OPENAI_TIMEOUT_SECONDS=45

# JSON dữ liệu ngành gửi vào AI predict. Đường dẫn tương đối tính từ project root.
# File bắt buộc có schema { "industry_insights": [...] }; không dùng Markdown digest ở đây.
INDUSTRY_MARKET_PATH=data/processed/market_signal_snapshot.json

# Supabase Project settings (để backend đọc/ghi dữ liệu liên kết tài khoản)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key_here
